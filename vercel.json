{
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "server/src/index.js",
			"use": "@vercel/node"
		}
	],
	"rewrites": [
		{
			"source": "/css/(.*)",
			"destination": "/css/$1"
		},
		{
			"source": "/js/(.*)",
			"destination": "/js/$1"
		},
		{
			"source": "/images/(.*)",
			"destination": "/images/$1"
		},
		{
			"source": "/p/:project/:file(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map))$",
			"destination": "/dist/:project/:file"
		},
		{
			"source": "/api/(.*)",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/p/([^/]+)/?$",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/p/([^/]+)/.*",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/",
			"destination": "/server/src/index.js"
		}
	]
}

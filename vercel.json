{
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "server/dist" }
		},
		{
			"src": "server/src/index.js",
			"use": "@vercel/node",
			"config": {
				"includeFiles": "apps.config.cjs|consts.js|server/**/*"
			}
		}
	],
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

{
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "server/src/public/**/*",
			"use": "@vercel/static"
		},
		{
			"src": "server/src/index.js",
			"use": "@vercel/node",
			"config": {
				"includeFiles": "server/**/*|dist/**/*|apps.config.js|consts.js"
			}
		}
	],
	"rewrites": [
		{
			"source": "/css/:file*",
			"destination": "/server/src/public/css/:file*"
		},
		{
			"source": "/js/:file*",
			"destination": "/server/src/public/js/:file*"
		},
		{
			"source": "/images/:file*",
			"destination": "/server/src/public/images/:file*"
		},
		{
			"source": "/p/:project/:file*",
			"destination": "/dist/:project/:file*"
		},
		{
			"source": "/p/:project/:path*",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/api/(.*)",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

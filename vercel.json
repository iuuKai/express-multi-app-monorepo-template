{
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "server/src/index.js",
			"use": "@vercel/node"
		}
	],
	"rewrites": [
		{
			"source": "^/p/([^/]+)/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))$",
			"destination": "/$1/$2"
		},
		{
			"source": "/api/(.*)",
			"destination": "/server/src/index.js"
		},
		{
			"source": "^/p/([^/]+)/?$",
			"destination": "/server/src/index.js"
		},
		{
			"source": "^/p/([^/]+)/.*$",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/",
			"destination": "/server/src/index.js"
		}
	]
}

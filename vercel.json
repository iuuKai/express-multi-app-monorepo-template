{
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "server/src/public/**/*",
			"use": "@vercel/static"
		},
		{
			"src": "server/src/index.js",
			"use": "@vercel/node"
		}
	],
	"rewrites": [
		{
			"source": "/css/:file*",
			"destination": "/css/:file*"
		},
		{
			"source": "/js/:file*",
			"destination": "/js/:file*"
		},
		{
			"source": "/images/:file*",
			"destination": "/images/:file*"
		},
		{
			"source": "/p/:project/:file*",
			"destination": "/dist/:project/:file*"
		},
		{
			"source": "/p/:project/:path*",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/api/(.*)",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/",
			"destination": "/server/src/index.js"
		}
	]
}

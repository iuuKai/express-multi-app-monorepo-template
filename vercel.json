{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"buildCommand": "yarn build:all",
	"installCommand": "yarn install:all",
	"builds": [
		{ "src": "apps.config.js", "use": "@vercel/static" },
		{ "src": "consts.js", "use": "@vercel/static" },
		{ "src": "server/src/public/**/*", "use": "@vercel/static" },
		{ "src": "server/dist/**/*", "use": "@vercel/static" },
		{
			"src": "server/src/index.js",
			"use": "@vercel/node",
			"config": {
				"includeFiles": ["apps.config.js", "consts.js", "server/**/*", "package.json"]
			}
		}
	],
	"rewrites": [
		{
			"source": "/p/:project([^/]+)/:file(.*\\.\\w+)$",
			"destination": "/server/dist/$1/$2"
		},
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

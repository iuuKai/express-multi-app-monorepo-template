{
	"version": 2,
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "yarn build:all",
	"installCommand": "yarn install:all",
	"outputDirectory": "server",
	"framework": null,
	"functions": {
		"server/src/index.js": {
			"runtime": "nodejs20.x"
		}
	},
	"rewrites": [
		{
			"source": "/p/:project([^/]+)/:file(.*\\.\\w+)$",
			"destination": "/server/dist/$1/$2"
		},
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

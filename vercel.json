{
	"version": 2,
	"build": {
		"env": {},
		"command": "pnpm install:all && pnpm build:all",
		"outputDirectory": "server",
		"devCommand": "pnpm dev"
	},
	"functions": {
		"server/src/index.js": {
			"runtime": "nodejs20"
		}
	},
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

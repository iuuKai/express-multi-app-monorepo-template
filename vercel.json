{
	"version": 2,
	"builds": [
		{
			"src": "server/src/index.js",
			"use": "@vercel/node",
			"config": {
				"buildCommand": "pnpm scripts/build-all.js",
				"includeFiles": [
					"package.json",
					"pnpm-lock.yaml",
					"scripts/**/*",
					"apps.config.js",
					"consts.js",
					"server/**/*"
				]
			}
		}
	],
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

{
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "server/src/index.js",
			"use": "@vercel/node"
		}
	],
	"routes": [
		{
			"src": "/p/([^/]+)/.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map)$",
			"dest": "/$1/$2"
		},
		{
			"src": "/api/(.*)",
			"dest": "/server/src/index.js"
		},
		{
			"src": "^/p/([^/]+)/?$",
			"dest": "/server/src/index.js"
		},
		{
			"src": "^/p/([^/]+)/.*$",
			"dest": "/server/src/index.js"
		},
		{
			"src": "/",
			"dest": "/server/src/index.js"
		}
	]
}

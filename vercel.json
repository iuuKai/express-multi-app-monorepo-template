{
	"version": 2,
	"buildCommand": "pnpm install:all && pnpm build:all",
	"devCommand": "pnpm dev",
	"build": {
		"env": {},
		"outputDirectory": "server"
	},
	"functions": {
		"server/src/index.js": {
			"runtime": "nodejs20"
		}
	},
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

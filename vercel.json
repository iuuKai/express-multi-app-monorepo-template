{
	"version": 2,
	"buildCommand": "yarn build:all",
	"installCommand": "yarn install:all",
	"functions": {
		"server/src/index.js": {
			"includeFiles": ["apps.config.js", "consts.js", "server/**/*"]
		}
	},
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/$1"
		},
		{
			"source": "/p/:project/:file*",
			"destination": "/server/dist/$project/$file*"
		},
		{
			"source": "/api/(.*)",
			"destination": "/server/src/index.js"
		},
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}

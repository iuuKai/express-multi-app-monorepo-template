{
	"version": 2,
	"builds": [
		{
			"src": "package.json",
			"use": "@vercel/static-build",
			"config": {
				"distDir": "server/dist",
				"buildCommand": "pnpm build:all",
				"installCommand": "pnpm install:all"
			}
		},
		{
			"src": "server/src/index.js",
			"use": "@vercel/node",
			"config": {
				"includeFiles": ["scripts/**/*", "apps.config.js", "consts.js", "server/**/*"]
			}
		}
	],
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/server/src/index.js"
		}
	]
}
